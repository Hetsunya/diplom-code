FROM golang:1.23-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/server ./cmd/server

FROM alpine:3.20

WORKDIR /app

RUN apk add --no-cache wget

COPY --from=builder /out/server /app/server

EXPOSE 8080

CMD ["/app/server"]
