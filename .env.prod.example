# === Public ===
# Your real domain name (used by Caddy for HTTPS)
DOMAIN=emeeting.example.com

# === Backend ===
SERVER_PORT=8080
# Comma-separated list of allowed origins (should match https domain in prod)
CORS_ALLOW_ORIGIN=https://${DOMAIN}

# REQUIRED: secret used to sign JWT access tokens
JWT_SECRET=change-me-very-long-random

# === Postgres ===
POSTGRES_DB=emeeting
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# Internal DSN used by backend container (do not expose publicly)
POSTGRES_DSN=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}?sslmode=disable

# === UI ===
# UI uses same-origin proxy on prod, keep these as defaults
VITE_API_URL=/api
VITE_WS_URL=/ws

# === Optional: AI profile (docker-compose.prod.yml --profile ai) ===
# SPEECH_ASR_ENGINE=whisper
# WHISPER_MODEL_SIZE=base
# AI_GATEWAY_SESSION_ID=1
# BACKEND_WS_BASE_URL=ws://backend:8080
# AI_GATEWAY_EMAIL=demo1@example.com
# AI_GATEWAY_PASSWORD=demo1pass
