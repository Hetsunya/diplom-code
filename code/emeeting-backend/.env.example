POSTGRES_DSN=postgres://postgres:1040@localhost:5432/emeeting?sslmode=disable
SERVER_PORT=8080
# Comma-separated list. Backend also allows private dev IPs on :5173.
CORS_ALLOW_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Optional: override SameSite for auth cookies (strict | lax | none). Default: heuristic —
# same hostname as API → Lax (прод за одним доменом); иначе None для кросс-сайт dev.
# AUTH_COOKIE_SAMESITE=lax
